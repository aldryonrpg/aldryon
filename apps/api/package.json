{
  "name": "@aldryon/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:integration:coverage": "bun --config=bunfig.integration.toml test tests/integration && bun run scripts/check-usecase-coverage.ts"
  },
  "dependencies": {
    "@aldryon/dtos": "workspace:*",
    "hono": "4.12.28",
    "jose": "6.2.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.4",
    "@types/bun": "1.3.14",
    "testcontainers": "12.0.4",
    "typescript": "6.0.3"
  }
}
