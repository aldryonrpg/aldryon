PORT=3001

# Supabase Auth (GoTrue) — the project's public URL, used to build the JWKS
# endpoint (${SUPABASE_URL}/auth/v1/.well-known/jwks.json) access tokens are
# verified against locally. Not a secret (same value as
# NEXT_PUBLIC_SUPABASE_URL) — no network call to Supabase's Auth server on
# the request path, and no Supabase SDK client needed — apps/api talks to
# Postgres directly (see DATABASE_URL below).
SUPABASE_URL=https://your-project.supabase.co

# Direct Postgres connection string (Supabase Project Settings > Database >
# Connection string). Integration tests override this with a
# testcontainers-provisioned Postgres instead of hitting a real project.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

SET_ATTRIBUTE_BONUS=2

STATUS_COOLDOWN_ROUNDS=5

LEVEL_UP_ATTRIBUTE_POINTS=4
