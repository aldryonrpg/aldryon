PORT=3001

# Supabase Auth (GoTrue) — used only to verify Google login tokens.
# apps/api is a trusted backend, so data access bypasses PostgREST/RLS and
# goes straight to Postgres (see DATABASE_URL below).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Direct Postgres connection string (Supabase Project Settings > Database >
# Connection string). Integration tests override this with a
# testcontainers-provisioned Postgres instead of hitting a real project.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

SET_ATTRIBUTE_BONUS=2

STATUS_COOLDOWN_ROUNDS=5

LEVEL_UP_ATTRIBUTE_POINTS=4
