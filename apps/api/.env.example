PORT=3001

# Supabase Auth (GoTrue) — the project's public URL, used to build the JWKS
# endpoint (${SUPABASE_URL}/auth/v1/.well-known/jwks.json) access tokens are
# verified against locally. Not a secret (same value as
# NEXT_PUBLIC_SUPABASE_URL) — no network call to Supabase's Auth server on
# the request path, and no Supabase SDK client needed — apps/api talks to
# Postgres directly (see DATABASE_URL below).
SUPABASE_URL=https://your-project.supabase.co

# Postgres connection string (Supabase Project Settings > Database >
# Connection string). Integration tests override this with a
# testcontainers-provisioned Postgres instead of hitting a real project.
#
# Use the pooler host (aws-*.pooler.supabase.com), never the direct
# db.<ref>.supabase.co host — the direct one often only resolves over IPv6,
# which Docker/container network setups (local Podman, Render) frequently
# can't reach at all, causing ERR_POSTGRES_CONNECTION_CLOSED. The pooler
# host supports two modes on two different ports — pick SESSION mode:
#
#   SESSION mode (port 5432, recommended/default): one stable backend per
#   connection for its lifetime, so prepared statements are safe.
#   DATABASE_POOL_PREPARE=true.
#
#   TRANSACTION mode (port 6543): higher connection reuse, but Supavisor can
#   hand a query to a different backend than the one that prepared it —
#   causes intermittent "bind message has N result formats but query has M
#   columns" / wrong-type 500s under concurrent requests (confirmed live).
#   DATABASE_POOL_PREPARE=false is mandatory if you use this mode.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-your-region.pooler.supabase.com:5432/postgres
DATABASE_POOL_PREPARE=true

SET_ATTRIBUTE_BONUS=2

STATUS_COOLDOWN_ROUNDS=5

LEVEL_UP_ATTRIBUTE_POINTS=4
