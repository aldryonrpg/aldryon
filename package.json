{
  "name": "aldryon",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/shared/*"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test:api": "bun test --cwd apps/api",
    "test:api:unit": "bun test --cwd apps/api tests/unit",
    "test:api:integration": "bun test --cwd apps/api tests/integration",
    "test:api:integration:coverage": "bun run --cwd apps/api test:integration:coverage",
    "dev:web": "bun --cwd apps/web run dev",
    "dev:api": "bun --cwd apps/api run dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
