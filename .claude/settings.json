{
  "permissions": {
    "allow": [
      "Read(.claude/**)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Read(**/*.md)",
      "Edit(**/*.md)",
      "Write(**/*.md)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/ask-on-delete.ts\""
          }
        ]
      }
    ]
  }
}
