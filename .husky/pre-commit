bunx lint-staged

echo "Vulnerability check (bun audit)"
bun audit --audit-level=high || exit 1

if git diff --cached --name-only | grep -q '^apps/api/'; then
  echo "apps/api changes detected — running back-end quality gates"
  bun run test:api:unit || exit 1
  bun run test:api:integration:coverage || exit 1
fi
